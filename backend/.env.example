APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=worldos
DB_USERNAME=worldos
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

# WorldOS: Simulation engine. Leave empty for stub. Use http://localhost:50052 for HTTP bridge (Rust), or host:50051 for gRPC.
SIMULATION_ENGINE_GRPC_URL=
# Phase 5: Tick driver. rust_only = tick from Rust only, Laravel syncs state/fires events. laravel_kernel = allow SimulationKernel post-tick when SIMULATION_KERNEL_POST_TICK=true.
# WORLDOS_SIMULATION_TICK_DRIVER=rust_only
# SIMULATION_KERNEL_POST_TICK=false
# Phase 5 Track A: event_bus driver. database | redis_stream (XADD then persist+dispatch).
# WORLDOS_EVENT_BUS_DRIVER=database
# WORLDOS_EVENT_BUS_STREAM_KEY=world_events
# Phase 5 Track B: Neo4j graph sync. Set WORLDOS_GRAPH_ENABLED=true and WORLDOS_GRAPH_URI to enable.
# WORLDOS_GRAPH_ENABLED=false
# WORLDOS_GRAPH_URI=http://localhost:7474
# WORLDOS_GRAPH_USERNAME=
# WORLDOS_GRAPH_PASSWORD=
# WORLDOS_CAUSALITY_DRIVER=null (default) | redis
WORLDOS_GUARANTEED_DEATHS_PER_TICK=0
WORLDOS_ACTOR_MINIMUM_POPULATION=1000

# --- WorldOS: Autonomic (AEE fork/archive/mutate) ---
# WORLDOS_FORK_ENTROPY_MIN=0.5
# WORLDOS_ARCHIVE_ENTROPY_THRESHOLD=0.99
# WORLDOS_STAGNATION_THRESHOLD=0.1
# WORLDOS_MAX_FORK_BRANCHES=1
# WORLDOS_MERGE_SIMILARITY_THRESHOLD=0.92
# WORLDOS_PROMOTE_MILESTONE_COMPLEXITY=0
# WORLDOS_PROMOTE_MILESTONE_CIV_COUNT=0

# --- WorldOS: Scheduler (Phase B, tick budget per world) ---
WORLDOS_SCHEDULER_TICK_BUDGET=50
# WORLDOS_SCHEDULER_WEIGHT_NOVELTY=0.25
# WORLDOS_SCHEDULER_WEIGHT_COMPLEXITY=0.30
# WORLDOS_SCHEDULER_WEIGHT_CIVILIZATION=0.25
# WORLDOS_SCHEDULER_WEIGHT_ENTROPY=0.20

# --- WorldOS: Timeline Selection (Phase C) ---
# WORLDOS_TIMELINE_SELECTION_LIMIT=10
# WORLDOS_TSE_WEIGHT_NOVELTY=0.25
# WORLDOS_TSE_WEIGHT_COMPLEXITY=0.25
# WORLDOS_TSE_WEIGHT_DIVERGENCE=0.20
# WORLDOS_TSE_WEIGHT_DEPTH=0.15
# WORLDOS_TSE_WEIGHT_TENSION=0.15

# --- WorldOS: Narrative Extraction (Phase D) ---
# WORLDOS_NARRATIVE_EXTRACTION_LIMIT=5
# WORLDOS_NARRATIVE_EXTRACTION_TYPE=lore

# --- WorldOS: Civilization Memory (Phase E) ---
# WORLDOS_CIV_MEMORY_MAX_EVENTS=50
# WORLDOS_CIV_MEMORY_MAX_CHRONICLES=30

# --- WorldOS: Mythology Generator (Phase F) ---
# WORLDOS_MYTHOLOGY_CHRONICLE_TYPE=myth

# --- WorldOS: Ideology Evolution (Phase G) ---
# WORLDOS_IDEOLOGY_STORE_IN_STATE=true

# --- WorldOS: Great Person (Phase H) ---
# WORLDOS_GREAT_PERSON_ENTROPY_MIN=0.3
# WORLDOS_GREAT_PERSON_ENTROPY_MAX=0.75
# WORLDOS_GREAT_PERSON_MIN_INSTITUTIONS=1
# WORLDOS_GREAT_PERSON_COOLDOWN_TICKS=500

# --- WorldOS: Pulse (Phase K, run ideology/great-person each pulse) ---
# WORLDOS_PULSE_RUN_IDEOLOGY=true
# WORLDOS_PULSE_RUN_GREAT_PERSON=true

# WorldOS: Narrative LLM (OpenAI or compatible). Set OPENAI_API_KEY for chronicle generation.
# OPENAI_API_KEY=
# NARRATIVE_LLM_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com
# NARRATIVE_LLM_URL=
# NARRATIVE_LLM_KEY=
# NARRATIVE_LLM_TIMEOUT=30

# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
